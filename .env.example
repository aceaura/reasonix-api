# Server
PORT=8088
HOST=0.0.0.0

# Authentication (empty = allow all clients; set a value to require it)
API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Session / conversation tracking
SESSION_TTL_MINUTES=60
MAX_CONCURRENT_SESSIONS=100

# Model mapping (OpenAI model name -> REAL DeepSeek API model)
# Use models the API actually serves: deepseek-chat, deepseek-reasoner.
DEFAULT_MODEL=deepseek-chat
MODEL_GPT_4O=deepseek-chat
MODEL_GPT_4O_MINI=deepseek-chat
MODEL_GPT_35_TURBO=deepseek-chat

# Limits
MAX_TOKENS=4096
BUDGET_USD=10.0

# Reasoning
REASONING_EFFORT=high
LOG_LEVEL=info
CORS_ORIGINS=*

# Local response short-circuit cache (exact prefix+turn+tools match -> 0 tokens). Default off.
ENABLE_RESPONSE_CACHE=false
